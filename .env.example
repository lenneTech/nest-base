# nest-base — generated by setup-wizard
# Copy this file to `.env` and fill in the placeholder secrets.
# `bun run setup` will copy + auto-generate strong secrets for you.

# ── Server boot ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=https://api.nest-base.localhost
# Where your problem-details `type` URLs resolve to (RFC 7807).
ERROR_DOC_BASE_URL=https://errors.example.com

# ── Database (Postgres + docker-compose interpolation) ────────
POSTGRES_USER=nest-base
POSTGRES_PASSWORD=change-me-strong-pass
POSTGRES_DB=nest-base
DATABASE_URL=postgresql://nest-base:change-me-strong-pass@localhost:5432/nest-base

# ── Docker Compose ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=nest-base
POSTGRES_HOST_PORT=5432

# ── Auth (Better-Auth) ─────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-32-chars-minimum-XXXXXX

# ── System bootstrap (matched pair, unset to skip auto-admin) ──
SYSTEM_SETUP_ADMIN_EMAIL=admin@example.com
SYSTEM_SETUP_ADMIN_PASSWORD=change-me-12-chars-min

# ── Object storage (RustFS / S3-compatible) ────────────────────
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=rustfs-secret

# ── Multi-tenancy ──────────────────────────────────────────────
TENANT_HEADER=x-tenant-id

# ── Email ──────────────────────────────────────────────────────
# Default points at the Mailpit container in docker-compose
# (`docker compose up -d mailpit`, web UI on http://localhost:8025).
# For production, set SMTP_HOST/PORT/USER/PASS to your real relay or
# switch the provider to Brevo via FEATURE_EMAIL_PROVIDER=brevo.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Sender address for outbound mail. Override per environment.
SMTP_FROM=no-reply@example.com
# Implicit-TLS (port 465). Leave false for STARTTLS (587) or plain dev.
SMTP_SECURE=false
# Force STARTTLS upgrade on a non-secure port. Off by default so dev
# relays without TLS (Mailpit) keep working out of the box.
SMTP_REQUIRE_TLS=false
# Outbound connection pool size + per-attempt timeout (ms). Outbox
# (#11) handles retries; the driver itself fails fast.
SMTP_POOL_SIZE=5
SMTP_TIMEOUT_MS=10000

# Brevo (transactional API). Required when FEATURE_EMAIL_PROVIDER=brevo
# OR when you want to use sendTemplate({ brevoTemplateId }) alongside SMTP.
# Get a key at https://app.brevo.com/settings/keys/api.
BREVO_API_KEY=

# ── Field encryption (32-byte base64 KEK; rotate via versioned tags) ─
FIELD_ENCRYPTION_KEK=

# ── PowerSync (mobile offline-sync) ────────────────────────────
POWERSYNC_DB_PASSWORD=change-me-powersync-replication-pass
POWERSYNC_JWKS_URL=http://host.docker.internal:3000/.well-known/jwks
POWERSYNC_URL=http://localhost:8080
POWERSYNC_TOKEN=

# ── Observability (optional) ───────────────────────────────────
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# ── Feature flags ──────────────────────────────────────────────
# Override schema defaults from src/core/features/features.ts.
# Uncomment + edit a line to toggle. Booleans accept
# true/false/1/0/yes/no/on/off (case-insensitive); arrays are
# comma-separated. See README "Configuring features".

# Auth methods
# FEATURE_AUTH_METHODS_EMAIL_PASSWORD=true
# FEATURE_AUTH_METHODS_TWO_FACTOR=true
# FEATURE_AUTH_METHODS_PASSKEY=true
# FEATURE_AUTH_METHODS_API_KEYS=true
# FEATURE_AUTH_METHODS_SOCIAL_PROVIDERS=

# Multi-tenancy
# FEATURE_MULTI_TENANCY_ENABLED=true
# FEATURE_MULTI_TENANCY_RLS=true
# FEATURE_MULTI_TENANCY_HEADER_NAME=x-tenant-id

# Files (TUS uploads, storage adapter, image transforms)
# FEATURE_FILES_ENABLED=true
# FEATURE_FILES_STORAGE_DEFAULT=local
# FEATURE_FILES_TUS=true
# FEATURE_FILES_TRANSFORMATIONS=true

# ── File storage (origin + cache) ──────────────────────────────
# Local driver — filesystem under STORAGE_LOCAL_ROOT (default ./data/uploads)
# STORAGE_LOCAL_ROOT=./data/uploads
# Public-facing base URL the LocalStorageAdapter signs into (defaults to APP_BASE_URL)
# STORAGE_BASE_URL=https://api.example.com/files
# S3 driver — uncomment when FEATURE_FILES_STORAGE_DEFAULT=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_MAX_TTL_SECONDS=3600

# ── TUS resumable uploads ──────────────────────────────────────
# Hard cap per single upload (bytes); default 50MB
# TUS_MAX_UPLOAD_BYTES=52428800
# Per-tenant total quota across in-progress uploads (bytes); default unset = no quota
# TUS_MAX_BYTES_PER_TENANT=
# Chunk expiration (seconds) — sweeps stale resumable uploads; default 24h
# TUS_CHUNK_EXPIRATION_SECONDS=86400

# Email
# FEATURE_EMAIL_ENABLED=true
# FEATURE_EMAIL_PROVIDER=smtp

# Cross-cutting (default on)
# FEATURE_RATE_LIMIT_ENABLED=true
# FEATURE_IDEMPOTENCY_ENABLED=true
# FEATURE_OBSERVABILITY_ENABLED=true
# FEATURE_JOBS_ENABLED=true

# Opt-in features (default off)
# FEATURE_WEBHOOKS_ENABLED=false
# FEATURE_SEARCH_ENABLED=false
# FEATURE_REALTIME_ENABLED=false
# FEATURE_POWERSYNC_ENABLED=false
# FEATURE_MCP_ENABLED=false
# FEATURE_FIELD_ENCRYPTION_ENABLED=false

# Geo (PostGIS, geocoding)
# FEATURE_GEO_ENABLED=false
# FEATURE_GEO_PROVIDER=nominatim

# GeoIP (offline IP→country/city lookup via .mmdb)
# Default provider `dbip-lite` is CC-BY-4.0, no key required, monthly snapshot.
# `bun run scripts/download-geoip.ts` populates `./data/geoip/city.mmdb`.
# FEATURE_GEO_IP_ENABLED=false
# FEATURE_GEO_IP_PROVIDER=dbip-lite
# FEATURE_GEO_IP_DB_PATH=./data/geoip/city.mmdb
#
# Opt-in: MaxMind GeoLite2-City for higher accuracy + weekly updates.
# Free signup at https://www.maxmind.com/en/geolite2/signup. NB: every
# download leaks the caller's IP to MaxMind — pick `dbip-lite` for
# Schrems-II-strict setups.
# FEATURE_GEO_IP_PROVIDER=maxmind
# FEATURE_GEO_IP_LICENSE_KEY=
