{
  "name": "nest-base",
  "version": "0.0.0",
  "description": "Template-fähiger NestJS-Server (Bun + Prisma + Postgres + Better-Auth)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "build:dev-portal": "bun run scripts/build-dev-portal.ts",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "oxfmt --check src tests",
    "format:check": "oxfmt --check src tests",
    "format:fix": "oxfmt src tests",
    "check:disqualifiers": "bun run scripts/disqualifier-scan.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:e2e": "vitest run --passWithNoTests",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:summary": "vitest run --passWithNoTests --reporter=json --outputFile=coverage/test-summary.json",
    "test:perf": "k6 run tests/k6/memory-test.js",
    "prisma:generate": "prisma generate && bun run scripts/postinstall-prisma-symlink.ts",
    "prisma:migrate": "prisma migrate deploy",
    "postinstall": "bun run scripts/postinstall-prisma-symlink.ts",
    "prepare:schema": "bun run scripts/prepare-schema.ts",
    "prepare:schema:check": "bun run scripts/prepare-schema.ts --check",
    "check:rls": "bun run scripts/check-rls.ts",
    "doctor": "bun run scripts/doctor.ts",
    "onboard": "bun run scripts/onboard.ts",
    "add:module": "bun run scripts/add-module.ts",
    "rename": "bun run scripts/rename-project.ts",
    "reset": "bun run scripts/reset.ts",
    "hub:reset-password": "bun run scripts/hub-reset-password.ts",
    "seed": "bun run scripts/seed.ts",
    "setup": "bun run scripts/setup-wizard.ts",
    "sync:from-template": "bun run scripts/sync-from-template.ts",
    "sync:to-template": "bun run scripts/sync-to-template.ts",
    "sdk:generate": "kubb generate -c kubb.config.ts",
    "sdk:check": "bun run scripts/sdk-check.ts",
    "dump:openapi": "bun run scripts/dump-openapi.ts",
    "docs:screenshots": "bun run scripts/take-showcase-screenshots.ts",
    "geoip:download": "bun run scripts/download-geoip.ts",
    "llm-test": "bun run scripts/llm-feature-test.ts"
  },
  "devDependencies": {
    "@kubb/cli": "^4.37.4",
    "@kubb/core": "^4.37.4",
    "@kubb/plugin-oas": "^4.37.4",
    "@kubb/plugin-ts": "^4.37.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "pino-pretty": "^13.1.3",
    "portless": "^0.11",
    "prisma": "^7",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@casl/ability": "^6.8.1",
    "@casl/prisma": "^1.6.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.55",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217",
    "@opentelemetry/sdk-node": "^0.57",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@scalar/nestjs-api-reference": "^1.1.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5",
    "@tanstack/react-virtual": "^3.13.24",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.0",
    "better-auth": "^1.6.9",
    "bun-plugin-tailwind": "^0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "ipx": "^3.1.1",
    "lucide-react": "^1.14.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^7",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.1",
    "pino": "^10.3.1",
    "prom-client": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "maxmind": "^5"
  }
}
