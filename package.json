{
  "name": "nest-server-template",
  "version": "0.0.0",
  "description": "Template-fähiger NestJS-Server (Bun + Prisma + Postgres + Better-Auth)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun run scripts/build.ts",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "oxfmt --check src tests",
    "format:fix": "oxfmt src tests",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:e2e": "vitest run e2e-spec stories --passWithNoTests",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:perf": "k6 run tests/k6/memory-test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prepare:schema": "bun run scripts/prepare-schema.ts",
    "setup": "bun run scripts/setup-wizard.ts",
    "sync:from-template": "bun run scripts/sync-from-template.ts",
    "sync:to-template": "bun run scripts/sync-to-template.ts",
    "sdk:generate": "kubb generate"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "prisma": "^7",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}
