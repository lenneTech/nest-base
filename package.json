{
  "name": "nest-base",
  "version": "0.0.0",
  "description": "Template-fähiger NestJS-Server (Bun + Prisma + Postgres + Better-Auth)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "build:dev-portal": "bun run scripts/build-dev-portal.ts",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "oxfmt --check src tests",
    "format:check": "oxfmt --check src tests",
    "format:fix": "oxfmt src tests",
    "check:disqualifiers": "bun run scripts/disqualifier-scan.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:e2e": "vitest run --passWithNoTests",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:summary": "vitest run --passWithNoTests --reporter=json --outputFile=coverage/test-summary.json",
    "test:perf": "k6 run tests/k6/memory-test.js",
    "prisma:generate": "prisma generate && bun run scripts/postinstall-prisma-symlink.ts",
    "prisma:migrate": "prisma migrate deploy",
    "postinstall": "bun run scripts/postinstall-prisma-symlink.ts && git config core.hooksPath .githooks 2>/dev/null || true",
    "prepare:schema": "bun run scripts/prepare-schema.ts",
    "prepare:schema:check": "bun run scripts/prepare-schema.ts --check",
    "check:rls": "bun run scripts/check-rls.ts",
    "doctor": "bun run scripts/doctor.ts",
    "onboard": "bun run scripts/onboard.ts",
    "add:module": "bun run scripts/add-module.ts",
    "rename": "bun run scripts/rename-project.ts",
    "reset": "bun run scripts/reset.ts",
    "seed": "bun run scripts/seed.ts",
    "setup": "bun run scripts/setup-wizard.ts",
    "sync:from-template": "bun run scripts/sync-from-template.ts",
    "sync:to-template": "bun run scripts/sync-to-template.ts",
    "sdk:generate": "kubb generate -c kubb.config.ts",
    "sdk:check": "bun run scripts/sdk-check.ts",
    "dump:openapi": "bun run scripts/dump-openapi.ts",
    "docs:screenshots": "bun run scripts/take-showcase-screenshots.ts",
    "geoip:download": "bun run scripts/download-geoip.ts",
    "llm-test": "bun run scripts/llm-feature-test.ts",
    "check": "bun run lint && bun run format && bun run test:types && bun run test:unit && bun run test:e2e && bun run test:coverage && bun run build"
  },
  "devDependencies": {
    "@kubb/cli": "^4.39.2",
    "@kubb/core": "^4.39.2",
    "@kubb/plugin-oas": "^4.39.2",
    "@kubb/plugin-ts": "^4.39.2",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "pino-pretty": "^13.1.3",
    "portless": "^0.15.4",
    "prisma": "^7.9.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.24",
    "@bull-board/api": "^8.1.2",
    "@bull-board/express": "^8.1.2",
    "@bull-board/nestjs": "^8.1.2",
    "@casl/ability": "^7.0.1",
    "@casl/prisma": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-radio-group": "^1.4.4",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@scalar/nestjs-api-reference": "^1.2.11",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-virtual": "^3.14.8",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.2",
    "better-auth": "^1.6.24",
    "bullmq": "^5.80.10",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "ipx": "^3.1.1",
    "lucide-react": "^1.25.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "maxmind": "^5.0.6"
  },
  "resolutions": {
    "protobufjs": ">=8.0.2",
    "fast-uri": ">=3.1.2",
    "@hono/node-server": ">=1.19.13",
    "ip-address": ">=10.1.1"
  }
}
