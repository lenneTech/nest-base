// Prisma 7 schema for nest-server-template.
//
// Connection URL lives in `prisma.config.ts` (Prisma 7 moved it out of
// the schema). All tables and columns are snake_case (`@@map` / `@map`)
// to match Postgres convention; TS-side properties stay camelCase.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------- Diagnostic ----------

model HealthPing {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@map("_health_ping")
}

// ---------- Domain v1 ----------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  roles      Role[]
  members    TenantMember[]
  fileBlobs  FileBlob[]

  @@map("tenants")
}

enum TenantMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model TenantMember {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  tenantId  String             @map("tenant_id") @db.Uuid
  role      String
  status    TenantMemberStatus @default(INVITED)
  invitedAt DateTime?          @map("invited_at")
  joinedAt  DateTime?          @map("joined_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_members")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TenantMember[]
  apiKeys     ApiKey[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  lookupId   String    @unique @map("lookup_id") @db.Uuid
  hash       String
  name       String
  scopes     String[]
  userId     String    @map("user_id") @db.Uuid
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model FileBlob {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String
  mimeType  String   @map("mime_type")
  sizeBytes Int      @map("size_bytes")
  body      Bytes
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("file_blobs")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isPublic    Boolean  @default(false) @map("is_public")
  parentId    String?  @map("parent_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Role?        @relation("RoleHierarchy", fields: [parentId], references: [id])
  children Role[]       @relation("RoleHierarchy")
  policies RolePolicy[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Policy {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions Permission[]
  roles       RolePolicy[]

  @@map("policies")
}

model RolePolicy {
  roleId   String @map("role_id") @db.Uuid
  policyId String @map("policy_id") @db.Uuid

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([roleId, policyId])
  @@map("role_policies")
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  SHARE
}

model Permission {
  id         String           @id @default(uuid()) @db.Uuid
  policyId   String           @map("policy_id") @db.Uuid
  resource   String
  action     PermissionAction
  itemFilter Json?            @map("item_filter")
  fields     String[]
  validation Json?
  presets    Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, resource, action])
  @@map("permissions")
}
