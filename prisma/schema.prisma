// Prisma 7 schema for nest-server-template.
//
// Connection URL lives in `prisma.config.ts` (Prisma 7 moved it out of
// the schema). All tables and columns are snake_case (`@@map` / `@map`)
// to match Postgres convention; TS-side properties stay camelCase.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------- Diagnostic ----------

model HealthPing {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@map("_health_ping")
}

// ---------- Domain v1 ----------

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users   User[]
  roles   Role[]
  members TenantMember[]

  @@map("tenants")
}

enum TenantMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model TenantMember {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  tenantId  String             @map("tenant_id") @db.Uuid
  role      String
  status    TenantMemberStatus @default(INVITED)
  invitedAt DateTime?          @map("invited_at")
  joinedAt  DateTime?          @map("joined_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_members")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TenantMember[]
  apiKeys     ApiKey[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  lookupId   String    @unique @map("lookup_id") @db.Uuid
  hash       String
  name       String
  scopes     String[]
  userId     String    @map("user_id") @db.Uuid
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@map("roles")
}
