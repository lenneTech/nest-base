// ---------- Better-Auth Organization plugin tables (issue #118) ----------
//
// These three models are required by BA's Prisma adapter when the
// organization plugin is active. IDs are TEXT (not UUID) to match
// BA's opaque-string id convention; our existing Tenant UUIDs are
// cast to TEXT in the data-migration SQL so the RLS/CASL `tenantId`
// references continue to work unchanged.

model Organization {
  id          String   @id
  name        String
  slug        String?  @unique
  logo        String?
  createdAt   DateTime @map("created_at")
  metadata    String?

  members     Member[]
  invitations Invitation[]
  settings    TenantSettings?

  @@map("organization")
}

// ---------- TenantSettings (issue #87) ----------
//
// Operator-managed metadata for each Better-Auth Organization.
// One row per org (unique FK on organization_id). Not tenant-RLS-scoped
// because it is managed by global admins only — the @Can("manage",
// "TenantAdmin") guard on the controller is the access gate.
// `deletedAt` is the soft-delete watermark used by the restore/archive
// workflow; it does NOT drive RLS on the org itself.
model TenantSettings {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  organizationId String    @unique @map("organization_id")
