// ---------- AuditLog (PRD § Core Features § Audit) ----------

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  // INVOKE rows record actions where the actor uses authority over a
  // session/resource without mutating shape — impersonation start /
  // stop is the canonical case (SC.SUB.16). The metadata.kind field
  // disambiguates IMPERSONATION_START vs IMPERSONATION_STOP.
  INVOKE
  // REVOKE rows record session-revocation events (CF.AUTH.SESSIONS).
  // The action+kind pair lets the Audit Browser surface
  // session-revoke history per actor / per affected user without
  // mixing it into generic DELETE traffic. metadata.strategy carries
  // the revoke-strategy: single | bulk-by-user | bulk-by-user-except-current.
  REVOKE

  @@map("audit_action")
}

// ---------- OutboxEntry (CF.RT.04 + CF.WH.06 + CF.JOBS.01) ----------

// Backs the per-second OutboxWorker tick. Every domain write that
// fans out to webhooks / realtime / search-index appends here; the
// worker claims unprocessed rows in `seq` order, runs every
// registered dispatcher, and marks `processed_at` only when ALL
// dispatchers succeeded.
//
// Forward-only `seq` (auto-increment) preserves dispatch ordering
// across restarts. Survives restart by definition (this is what
// makes the outbox at-least-once).
model OutboxEntry {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  seq         Int       @default(autoincrement())
  tenantId    String    @map("tenant_id") @db.Uuid
  type        String
  payload     Json
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  processedAt DateTime? @map("processed_at")
  /// Stamped by `claimBatch` when the in-flight sentinel is written.
  /// `resetStaleSentinels` compares against this column (not `occurred_at`)
  /// so backlog events with old enqueue timestamps are not prematurely reset
  /// while a worker is still dispatching them (Finding 1 fix).
  claimedAt   DateTime? @map("claimed_at")
  /// Persisted dispatch attempts — survives pod restarts (OPEN_QUESTIONS MAJ-3).
  dispatchAttemptCount Int @default(0) @map("dispatch_attempt_count")

  @@index([processedAt, seq])
  @@map("outbox_entries")
}

