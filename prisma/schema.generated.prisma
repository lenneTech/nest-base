// ---------- PendingErasure (CF.GDPR.04 — 30-day grace) ----------

// Backs the GdprErasureRunner cron + the DELETE /me/account
// controller. A row materialises when the user requests deletion;
// the runner's daily tick erases (anonymises) the user once
// `requested_at` is more than 30 days ago and `cancelled_at` is
// NULL. `completed_at` is the idempotency watermark — the next tick
// skips rows where it is set.
model PendingErasure {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  requestedAt DateTime  @default(now()) @map("requested_at")
  cancelledAt DateTime? @map("cancelled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completedAt, cancelledAt, requestedAt])
  @@map("pending_erasures")
}

// Backs the audit Prisma extension: every CUD on an opted-in model
// emits an `AuditLog` row carrying the actor, the tenant, the target
// model + record id, the action, and a `{before?, after?}` JSON diff.
//
// The model lives in the always-on core schema so the table exists
// at migrate time even when `features.audit.enabled === false` — the
// feature flag controls whether the extension WRITES rows, not
// whether the table exists. This avoids the migrate-time skew of a
// feature-gated table that some installs have and others don't.
model AuditLog {
  id          String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  /// Nullable for system-level events (e.g. Better-Auth user creation
  /// before the user is associated with any tenant — issue #99).
  tenantId    String?     @map("tenant_id") @db.Uuid
  actorUserId String?     @map("actor_user_id") @db.Uuid
  targetModel String      @map("target_model")
  targetId    String      @map("target_id")
  action      AuditAction
  /// Diff payload — `{before?, after?}` JSON. Both keys are optional:
  ///   - CREATE → only `after`
  ///   - DELETE → only `before`
  ///   - UPDATE → both
  ///   - RESTORE → both, `after.deletedAt = null`
  diff        Json
  /// Optional metadata bag — request id / trace id / IP — captured
  /// from the AsyncLocalStorage context when available. Stored as
  /// JSON so projects can extend it (e.g. add user-agent) without
  /// schema migration.
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([targetModel, targetId])
  @@index([actorUserId, createdAt])
  @@map("audit_log")
}

/// Stripe-style idempotency record. Persists the cached response for a
/// (userId-scoped) idempotency key so replays survive a process
/// restart. The `key` column already encodes the userId via the
/// `scopeIdempotencyKey()` prefix in the service layer; storing the
/// raw `userId` separately lets the framework reason about ownership
/// without parsing the prefix.
///
/// `expiresAt` is the wall-clock cutoff after which the record is
/// treated as a miss; a periodic cleanup job (or a TTL-aware lookup)
/// can prune rows past this watermark. The service-side `now` is in
/// epoch milliseconds; the DB column is `TIMESTAMP(3)` and the
/// adapter converts at the boundary.
model IdempotencyRecord {
  /// Scoped key — `<userId | "anon">::<client-supplied-key>`.
  key         String   @id
  userId      String?  @map("user_id") @db.Uuid
  requestHash String   @map("request_hash")
  status      Int
  /// Cached response body. JSON so any handler shape round-trips.
  body        Json
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_records")
}

// ---------- SystemSecrets (Hub auth — issue #83) ----------

// Stores server-managed key/value secrets. Currently used for the Hub
// password hash (key = "hub_password_hash"). The table intentionally
// avoids foreign-key constraints — it is a system-level record store,
// not a domain entity. The `key` column acts as a named slot; the
// `value` column stores an opaque string (e.g. an argon2 hash).
// `updatedAt` lets operators audit when the hash was last rotated.
model SystemSecret {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_secrets")
}

// ---------- Rate-Limit Admin (issue #94) ----------

// Persists operator-configured rate-limit windows so live changes survive
// restarts without a code deploy. The service caches rows in memory and
// refreshes every 30 s; deletions trigger a cache flush that falls back to
// the hardcoded default for that scope.
model RateLimitConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope         String   @unique // "global:1s" | "global:1m" | "global:1h" | "auth:signIn" | "auth:signUp" | "auth:passwordReset" | "auth:verifyEmail"
  maxRequests   Int      @map("max_requests")
  windowSeconds Int      @map("window_seconds")
  updatedById   String?  @map("updated_by_id") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("rate_limit_configs")
}

// Sampled decision history: every block and ~1% of allows. The inspector
// and decisions tab read this for operator visibility into throttle patterns.
model RateLimitDecision {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bucketKey  String   @map("bucket_key")
  endpoint   String
  decision   String   // "allow" | "block"
  count      Int
  limit      Int
  windowSecs Int      @map("window_secs")
  ip         String?
  userId     String?  @map("user_id") @db.Uuid
  ts         DateTime @default(now()) @map("ts")

  @@index([bucketKey])
  @@index([ts])
  @@map("rate_limit_decisions")
}

// The throttler_records table is managed directly by the ThrottlerStorageService
// (Postgres-backed counter store). It has no Prisma model but exists in the DB
// so we declare it with @@ignore to prevent prisma migrate dev from including a
// DROP TABLE statement in consumer migrations.
model ThrottlerRecord {
  key       String   @id
  count     Int
  expiresAt DateTime @map("expires_at")

  @@ignore
  @@map("throttler_records")
}

// Users and IPs exempt from rate limiting. The throttler reads this on each
// request (cached) before touching the throttler_records counter.
model RateLimitAllowlist {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  reason      String
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("rate_limit_allowlist")
}

/// Asset-variant cache index (CF.STORAGE.01 closure — iter-183).
///
/// Discoverable index over the asset variant cache. The matching
/// rendered bytes live on the `StorageAdapter` cache (typically
/// `_cache/<cacheKey>`); this table maps each cacheKey back to its
/// source so cascade-invalidation on origin re-upload is O(log N)
/// instead of an O(N) walk over the `assets/*` prefix.
///
/// `cacheKey` is the same value `computeCacheKey({sourceKey,
/// options})` returns from `asset.service.ts`. `optionsHash` is the
/// hash of just the `TransformOptions` — useful for analytics +
/// dedup when two sources share the same transform recipe.
model AssetVariantIndex {
  /// Stable hash of `(sourceKey, options)` — primary key.
  cacheKey    String   @id @map("cache_key")
  sourceKey   String   @map("source_key")
  optionsHash String   @map("options_hash")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sourceKey])
  @@index([createdAt])
  @@map("asset_variant_index")
}
